{
  "name": "ecentric-apple-clientsdk",
  "version": "1.1.0",
  "description": "A lightweight client SDK for initiating secure payment requests with Apple Pay, featuring enterprise-grade security and rate limiting.",
  "main": "epsapplepay.js",
  "types": "epsapplepay.d.ts",
  "exports": {
    ".": {
      "types": "./epsapplepay.d.ts",
      "require": "./epsapplepay.js",
      "default": "./epsapplepay.js"
    }
  },
  "files": [
    "epsapplepay.js",
    "dist/epsapplepay.min.js",
    "epsapplepay.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:dev": "rollup -c --environment NODE_ENV:development",
    "build:watch": "rollup -c --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "docs": "jsdoc -c jsdoc.conf.json",
    "docs:serve": "jsdoc -c jsdoc.conf.json && npx http-server docs -p 8080 -o",
    "docs:clean": "rimraf docs",
    "docs:watch": "nodemon --watch src --ext js --exec \"npm run docs\"",
    "clean": "rimraf dist/",
    "prepublishOnly": "npm run clean && npm run build && npm test && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "https://dev.azure.com/epsdev/OnlinePayments/_git/Ecentric.ApplePay.ClientSdk"
  },
  "homepage": "https://dev.azure.com/epsdev/OnlinePayments/_git/Ecentric.ApplePay.ClientSdk",
  "bugs": {
    "url": "https://dev.azure.com/epsdev/OnlinePayments/_git/Ecentric.ApplePay.ClientSdk/issues"
  },
  "keywords": [
    "ecentric",
    "applepay",
    "apple-pay",
    "digitalwallets",
    "digital-wallets",
    "payments",
    "payment-gateway",
    "sdk",
    "client-sdk",
    "javascript",
    "browser",
    "enterprise"
  ],
  "author": {
    "name": "Francois van Eeden",
    "company": "Ecentric"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "better-docs": "^2.7.3",
    "eslint": "^8.57.1",
    "http-server": "^14.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdoc": "^4.0.5",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.2",
    "rollup": "^4.53.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}