{
  "name": "vq-digitalwallet-apple",
  "version": "1.1.0",
  "description": "A lightweight client SDK for initiating secure payment requests with Apple Pay, featuring enterprise-grade security and rate limiting.",
  "main": "vqdigitalwalletapple.js",
  "module": "dist/vqdigitalwalletapple.min.js",
  "types": "vqdigitalwalletapple.d.ts",
  "exports": {
    ".": {
      "require": "./vqdigitalwalletapple.js",
      "import": "./dist/vqdigitalwalletapple.min.js",
      "types": "./vqdigitalwalletapple.d.ts"
    }
  },
  "files": [
    "vqdigitalwalletapple.js",
    "dist/vqdigitalwalletapple.min.js",
    "vqdigitalwalletapple.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:dev": "rollup -c --environment NODE_ENV:development",
    "build:watch": "rollup -c --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "docs": "jsdoc -c jsdoc.conf.json",
    "docs:serve": "jsdoc -c jsdoc.conf.json && npx http-server docs -p 8080 -o",
    "docs:clean": "rimraf docs",
    "docs:watch": "nodemon --watch src --ext js --exec \"npm run docs\"",
    "clean": "rimraf dist/",
    "prepublishOnly": "npm run clean && npm run build && npm test && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Veritas-Quaesitor/vq-digitalwallet-apple.git"
  },
  "homepage": "https://veritas-quaesitor.github.io/vq-digitalwallet-apple/",
  "bugs": {
    "url": "https://github.com/Veritas-Quaesitor/vq-digitalwallet-apple/issues"
  },
  "keywords": [
    "vq",
    "veritas-quaesitor",
    "applepay",
    "apple-pay",
    "digitalwallets",
    "digital-wallets",
    "payments",
    "payment-gateway",
    "sdk",
    "client-sdk",
    "javascript",
    "browser",
    "enterprise"
  ],
  "author": "Veritas Quaesitor",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "docdash": "^2.0.2",
    "eslint": "^8.57.1",
    "http-server": "^14.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdoc": "^4.0.5",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.2",
    "rollup": "^4.53.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
