{
  "source": {
    "include": ["./src/", "./README.md"],
    "includePattern": "\\.(js)$",
    "exclude": ["node_modules/", "test/", "coverage/", "dist/"]
  },
  "opts": {
    "destination": "./docs/",
    "template": "node_modules/docdash",
    "recurse": true,
    "readme": "./README.md"
  },
  "plugins": [
    "plugins/markdown"
  ],
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  },
  "tags": {
    "allowUnknownTags": true
  },
  "metadata": {
    "title": "VQ Digital Wallet Apple Pay SDK Documentation",
    "version": "1.1.0"
  }
}
